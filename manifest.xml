<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
           xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0"
           xsi:type="MailApp">
  <Id>d88323f1-1f2c-4c41-9759-321bd36b72a2</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>PMI Lighthouse</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="LeadSimple Lookup" />
  <Description DefaultValue="Look up LeadSimple contacts and create follow-ups from Outlook" />
  <IconUrl DefaultValue="https://pland10.github.io/leadsimple-outlook-addin/icon-32.png" />
  <HighResolutionIconUrl DefaultValue="https://pland10.github.io/leadsimple-outlook-addin/icon-80.png" />
  <SupportUrl DefaultValue="https://www.pmilighthouse.com" />
  <AppDomains>
    <AppDomain>https://pland10.github.io</AppDomain>
    <AppDomain>https://vpphjzvesgrihqavzyfu.supabase.co</AppDomain>
    <AppDomain>https://app.leadsimple.com</AppDomain>
  </AppDomains>
  <Hosts>
    <Host Name="Mailbox" />
  </Hosts>
  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.1" />
    </Sets>
  </Requirements>
  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://pland10.github.io/leadsimple-outlook-addin/taskpane.html" />
        <RequestedHeight>450</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>
  <Permissions>ReadItem</Permissions>
  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read" />
  </Rule>
  <DisableEntityHighlighting>false</DisableEntityHighlighting>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Requirements>
      <bt:Sets DefaultMinVersion="1.3">
        <bt:Set Name="Mailbox" />
      </bt:Sets>
    </Requirements>
    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <ExtensionPoint xsi:type="MessageReadCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="lsGroup">
                <Label resid="groupLabel" />
                <Control xsi:type="Button" id="lsTaskpaneButton">
                  <Label resid="buttonLabel" />
                  <Supertip>
                    <Title resid="buttonLabel" />
                    <Description resid="buttonTip" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="icon16" />
                    <bt:Image size="32" resid="icon32" />
                    <bt:Image size="80" resid="icon80" />
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="taskpaneUrl" />
                    <SupportsPinning>true</SupportsPinning>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>
    <Resources>
      <bt:Images>
        <bt:Image id="icon16" DefaultValue="https://pland10.github.io/leadsimple-outlook-addin/icon-16.png" />
        <bt:Image id="icon32" DefaultValue="https://pland10.github.io/leadsimple-outlook-addin/icon-32.png" />
        <bt:Image id="icon80" DefaultValue="https://pland10.github.io/leadsimple-outlook-addin/icon-80.png" />
      </bt:Images>
      <bt:Urls>
        <bt:Url id="taskpaneUrl" DefaultValue="https://pland10.github.io/leadsimple-outlook-addin/taskpane.html" />
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="groupLabel" DefaultValue="LeadSimple" />
        <bt:String id="buttonLabel" DefaultValue="LeadSimple Lookup" />
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="buttonTip" DefaultValue="Look up this sender in LeadSimple and create a follow-up." />
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
